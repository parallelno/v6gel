# will have compiled files and executables
debug
/target

# Build outputs
build/
out/
*.bin
*.rom
*.lst
*.o
*.map
*.elf
*.symbols.json

# Release distributables
dist/

# Build logs and temp files
build.log
BUILD_STEPS.txt

# Python
__pycache__/
*.pyc

# temporary files
temp/

# External tools: only the preinstalled ay_emul is tracked. Everything else
# under tools/ is fetched by install_tools.py and must never be committed.
/tools/*
!/tools/ay_emul/